# Azure OpenAI Configuration (AI Foundry)
AZURE_OPENAI_ENDPOINT=https://your-service.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure AI Search Configuration
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-azure-search-api-key
AZURE_SEARCH_INDEX_NAME=your-index-name

# Azure Speech Services Configuration
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=swedencentral

# GitHub Configuration (for private repository images)
GITHUB_TOKEN=your-github-personal-access-token

# Azure Function App for Session Data
VITE_SESSION_DATA_ENDPOINT=https://your-function-app.azurewebsites.net/api/your-function-name

# Azure Function App for Bug Reports
VITE_BUG_REPORT_ENDPOINT=https://your-function-app.azurewebsites.net/api/bug-report

# Feature Flags
# Set to 'true' to enable Q&A mode, 'false' to disable it (pitch only mode)
VITE_QNA_ENABLED=true
# Set to 'true' to enable bug report feature, 'false' to disable it
VITE_BUG_REPORT_ENABLED=true
# Set to 'true' to load slides/room configurations from /api/content/* instead of local JSON
VITE_USE_CONTENT_API=false
# Blob media container used by frontend media proxy URL rewriting (/api/media/{container}/{path})
VITE_MEDIA_BLOB_CONTAINER=bluecrow-media
