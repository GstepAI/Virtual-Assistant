{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2019",
    "outDir": ".",
    "rootDir": ".",
    "sourceMap": false,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
